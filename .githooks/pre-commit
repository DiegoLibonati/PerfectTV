#!/bin/sh
# Pre-commit hook for Broadbase monorepo.
# Runs lint-staged inside each package when its files are staged.

REPO_ROOT="$(git rev-parse --show-toplevel)"
STAGED_FILES=$(git diff --cached --name-only)

API_FILES=$(echo "$STAGED_FILES" | grep "^broadbase-api/")
GRAPHQL_FILES=$(echo "$STAGED_FILES" | grep "^broadbase-graphql/")
APP_FILES=$(echo "$STAGED_FILES" | grep "^broadbase-app/")

EXIT_CODE=0

if [ -n "$API_FILES" ]; then
    echo "[pre-commit] Running lint-staged for broadbase-api..."
    cd "$REPO_ROOT/broadbase-api" && npx lint-staged
    EXIT_CODE=$((EXIT_CODE + $?))
fi

if [ -n "$GRAPHQL_FILES" ]; then
    echo "[pre-commit] Running lint-staged for broadbase-graphql..."
    cd "$REPO_ROOT/broadbase-graphql" && npx lint-staged
    EXIT_CODE=$((EXIT_CODE + $?))
fi

if [ -n "$APP_FILES" ]; then
    echo "[pre-commit] Running lint-staged for broadbase-app..."
    cd "$REPO_ROOT/broadbase-app" && npx lint-staged
    EXIT_CODE=$((EXIT_CODE + $?))
fi

exit $EXIT_CODE
